<!--pages/purchased/purchased.wxml-->
<view class="page-container">
  <!-- 已购短剧列表 -->
  <view class="list-container" wx:if="{{dramas.length > 0}}">
    <view
      class="drama-item"
      wx:for="{{dramas}}"
      wx:key="dramaId"
      data-id="{{item.dramaId}}"
      bindtap="goToDetail"
    >
      <image class="cover-image" src="{{item.coverUrl}}" mode="aspectFill" lazy-load />
      <view class="drama-info">
        <text class="drama-title">{{item.title}}</text>
        <view class="tag-row">
          <text class="tag {{item.unlockType === 'ALL' ? 'tag-all' : 'tag-single'}}">
            {{item.unlockType === 'ALL' ? '整部' : '单集'}}
          </text>
          <text class="unlock-count" wx:if="{{item.unlockType === 'SINGLE'}}">已解锁{{item.unlockCount}}集</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{dramas.length === 0 && !loading}}">
    <text class="empty-icon">🎬</text>
    <text class="empty-text">暂无已购短剧</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
