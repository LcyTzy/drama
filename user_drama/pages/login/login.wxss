page {
  height: 100vh;
  background: #f5f5f5;
}

.login-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 120rpx 60rpx 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

.form-card {
  margin: -40rpx 40rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 48rpx;
}

.input-group {
  margin-bottom: 36rpx;
}

.input-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  height: 88rpx;
  border-bottom: 2rpx solid #eee;
  font-size: 30rpx;
  color: #333;
}

.code-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eee;
}

.code-input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #333;
}

.code-btn {
  font-size: 26rpx;
  color: #e94560;
  padding: 12rpx 24rpx;
  white-space: nowrap;
}

.code-btn.disabled {
  color: #ccc;
}

.login-btn {
  margin-top: 60rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: #e94560;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}

/* 微信授权登录样式 */
.auth-card {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.wechat-auth-box {
  margin: 80rpx 40rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.auth-header {
  margin-bottom: 24rpx;
}

.auth-app-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.auth-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.auth-user-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.auth-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.auth-nickname {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.auth-check {
  font-size: 36rpx;
  color: #07c160;
  font-weight: bold;
}

.auth-user-sub {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
  padding-left: 24rpx;
}

.auth-buttons {
  display: flex;
  gap: 24rpx;
}

.auth-btn-reject,
.auth-btn-allow {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.auth-btn-reject {
  background: #f5f5f5;
  color: #666;
}

.auth-btn-allow {
  background: #07c160;
  color: #ffffff;
}

.auth-btn-reject::after,
.auth-btn-allow::after {
  border: none;
}

.phone-login-link {
  margin-top: 48rpx;
  text-align: center;
  padding: 24rpx;
}

.phone-login-link text {
  font-size: 28rpx;
  color: #07c160;
}

.back-to-wechat {
  margin-top: 32rpx;
  text-align: center;
  padding: 24rpx;
}

.back-to-wechat text {
  font-size: 28rpx;
  color: #07c160;
}
