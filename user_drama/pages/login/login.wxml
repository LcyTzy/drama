<view class="login-page">
  <!-- 微信授权登录（主入口） -->
  <view class="auth-card" wx:if="{{!showPhoneLogin}}">

    
    <view class="app-icon">
      <text class="app-title">短剧</text>
      <text class="app-subtitle">精彩短剧 尽在掌握</text>
    </view>

    <view class="wechat-auth-box">
      <view class="auth-header">
        <view class="auth-app-name">短剧 申请</view>
      </view>
      <view class="auth-desc">获取你的昵称、头像</view>
      <view class="auth-user-info">
        <image class="auth-avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="auth-nickname">{{nickname || '微信用户'}}</text>
        <text class="auth-check">✓</text>
      </view>
      <view class="auth-user-sub">微信个人信息</view>

      <view class="auth-buttons">
        <button class="auth-btn-reject" bindtap="onReject">拒绝</button>
        <button class="auth-btn-allow" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" bindtap="onAllow">允许</button>
      </view>
    </view>

    <view class="login-box">
      <button bindtap="wxOneKeyLogin" open-type="getUserProfile" type="primary">
    微信一键登录
      </button>
    </view>

    <view class="phone-login-link" bindtap="showPhoneLogin">
      <text>手机号登录</text>
    </view>
  </view>

  

  <!-- 手机号登录（备选） -->
  <view class="form-card" wx:else>
    <view class="form-title">手机号登录</view>

    <view class="input-group">
      <text class="input-label">手机号</text>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="input-group">
      <text class="input-label">验证码</text>
      <view class="code-row">
        <input
          class="code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view
          class="code-btn {{countdown > 0 ? 'disabled' : ''}}"
          bindtap="sendCode"
        >
          <text wx:if="{{countdown === 0}}">获取验证码</text>
          <text wx:else>{{countdown}}s后重新获取</text>
        </view>
      </view>
    </view>

    <button class="login-btn" bindtap="login" loading="{{loading}}">
      登录
    </button>

    <view class="back-to-wechat" bindtap="hidePhoneLogin">
      <text>返回微信登录</text>
    </view>
  </view>
</view>
