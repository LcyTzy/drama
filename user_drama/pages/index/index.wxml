<!--pages/index/index.wxml-->
<view class="page-container">
  <!-- 分类标签栏 -->
  <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      class="tab-item {{activeCategoryId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
      bindtap="onTabChange"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 短剧列表 -->
  <view class="drama-grid" wx:if="{{dramas.length > 0}}">
    <view
      class="drama-card"
      wx:for="{{dramas}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="cover-wrapper">
        <image
          wx:if="{{item.coverUrl}}"
          class="cover-image"
          src="{{item.coverUrl}}"
          mode="aspectFill"
          lazy-load
        />
        <view wx:else class="cover-placeholder">
          <text class="placeholder-text">暂无封面</text>
        </view>
      </view>
      <view class="card-info">
        <text class="drama-title">{{item.title}}</text>
        <view class="card-meta">
          <text class="category-name">{{item.categoryName}}</text>
          <text class="meta-divider">·</text>
          <text class="episode-count">共{{item.totalEpisodes}}集</text>
        </view>
        <view class="card-views">
          <text>{{item.views}}次观看</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{dramas.length === 0 && !loading}}">
    <text class="empty-icon">🎬</text>
    <text class="empty-text">暂无推荐短剧</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
