/* pages/player/player.wxss */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 视频播放器 */
.video-wrapper {
  position: relative;
  width: 100%;
  height: 420rpx;
  background-color: #000;
}

.video-player {
  width: 100%;
  height: 100%;
}

/* 弹幕浮动层 */
.danmaku-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 10;
}

.danmaku-float {
  position: absolute;
  right: 0;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.8);
  animation-name: danmakuSlide;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
}

@keyframes danmakuSlide {
  from {
    transform: translateX(100vw);
  }
  to {
    transform: translateX(-100%);
  }
}

/* 弹幕开关按钮 */
.danmaku-toggle {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
  z-index: 20;
}

.video-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
}

/* 剧集信息 */
.episode-info-bar {
  padding: 24rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.episode-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.episode-num-text {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 剧集列表（横向滚动） */
.episode-list-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin-top: 16rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.episode-scroll {
  white-space: nowrap;
  display: flex;
}

.episode-num-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fff;
}

.episode-num-item.active {
  border-color: #e94560;
  color: #e94560;
  font-weight: 600;
}

/* 弹幕区域 */
.danmaku-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin-top: 16rpx;
}

.danmaku-input-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.danmaku-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 36rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
}

.danmaku-send-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #e94560;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
}

.danmaku-list {
  max-height: 600rpx;
}

.danmaku-item-wrapper {
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.danmaku-item {
  position: relative;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  transition: transform 0.3s;
  z-index: 2;
}

.danmaku-item.swiped {
  transform: translateX(-120rpx);
}

.danmaku-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.danmaku-nickname {
  font-size: 24rpx;
  color: #999;
  flex: 1;
}

.danmaku-time {
  font-size: 22rpx;
  color: #bbb;
}

.danmaku-content {
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.danmaku-delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 120rpx;
  background-color: #e94560;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  z-index: 1;
}

.danmaku-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 底部导航栏 */
.bottom-nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 20rpx;
  z-index: 100;
}

.nav-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background-color: #e94560;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 36rpx;
}

.nav-btn.disabled {
  background-color: #ddd;
  color: #999;
}
