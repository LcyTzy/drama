<view class="user-page">
  <!-- 未登录状态 -->
  <view class="login-card" wx:if="{{!isLoggedIn}}" bindtap="onLoginTap">
    <view class="avatar-placeholder">
      <view class="placeholder-head"></view>
      <view class="placeholder-body"></view>
    </view>
    <text class="login-text">点击登录</text>
  </view>

  <!-- 已登录状态 -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname}}</text>
        <text class="phone">{{maskedPhone}}</text>
      </view>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="onMenuTap" data-page="/pages/purchased/purchased">
        <text class="menu-label">已购短剧</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-page="/pages/history/history">
        <text class="menu-label">观看历史</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="onLogoutTap">退出登录</view>
  </block>
</view>
