page {
  background: #f5f5f5;
}

.user-page {
  min-height: 100vh;
}

/* 未登录卡片 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 80rpx 40rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.placeholder-head {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.placeholder-body {
  width: 56rpx;
  height: 28rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 255, 255, 0.8);
}

.login-text {
  color: #ffffff;
  font-size: 30rpx;
  margin-top: 24rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
}

.user-info {
  display: flex;
  flex-direction: column;
  margin-left: 30rpx;
}

.nickname {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
}

.phone {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  margin-top: 12rpx;
}

/* 菜单列表 */
.menu-list {
  margin-top: 20rpx;
  background: #ffffff;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-btn {
  text-align: center;
  color: #e94560;
  font-size: 30rpx;
  margin-top: 40rpx;
  padding: 24rpx 0;
  background: #ffffff;
}

.logout-btn:active {
  background: #f9f9f9;
}
