<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zhenyu.drama.mapper.DramaMapper">

    <update id="update">
        update drama
        <set>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId},
            </if>
            <if test="coverUrl != null">
                cover_url = #{coverUrl},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="director != null">
                director = #{director},
            </if>
            <if test="actor != null">
                actor = #{actor},
            </if>
            <if test="priceType != null">
                price_type = #{priceType},
            </if>
            <if test="pricePerEpisode != null">
                price_per_episode = #{pricePerEpisode},
            </if>
            <if test="packagePrice != null">
                package_price = #{packagePrice},
            </if>
            <if test="freeEpisodes != null">
                free_episodes = #{freeEpisodes},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="totalEpisodes != null">
                total_episodes = #{totalEpisodes},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="updateUser != null">
                update_user = #{updateUser},
            </if>
        </set>
        where id = #{id}
    </update>

    <select id="pageQuery" resultType="com.zhenyu.pojo.entity.Drama">
        select * from drama
        <where>
            <if test="title != null and title != ''">
                and title like concat('%',#{title},'%')
            </if>
            <if test="categoryId != null">
                and category_id = #{categoryId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>
</mapper>
